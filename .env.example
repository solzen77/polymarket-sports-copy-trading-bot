# Backend configuration (.env)
# Copy this file to `.env` and fill in values.
#
# Notes:
# - Any value can be omitted; defaults will be used where safe.
# - When env vars are present, the backend will prefer env over `config.json`.

# --- Polymarket endpoints ---
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com

# --- Polymarket credentials (required for LIVE trading via CLOB) ---
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# POLYMARKET_PRIVATE_KEY=
# Optional:
# POLYMARKET_PROXY_WALLET_ADDRESS=
# POLYMARKET_SIGNATURE_TYPE=0

# --- Trailing bot trading settings ---
# TRADING_SLUG=will-the-oklahoma-city-thunder-win-the-2026-nba-finals
TRADING_CONTINUOUS=false
TRADING_CHECK_INTERVAL_MS=1000
TRADING_TRAILING_STOP_POINT=0.03
TRADING_TRAILING_SHARES=10
TRADING_FIXED_TRADE_AMOUNT=1
TRADING_MIN_TIME_REMAINING_SECONDS=30
TRADING_SELL_PRICE=0.99

# --- Copy trading (optional) ---
# Comma-separated lists.
# COPY_TRADING_SLUGS=some-market-slug,another-market-slug
# COPY_TRADING_TRADERS=0xabc...,0xdef...
# COPY_TRADING_POLL_INTERVAL_MS=3000
# COPY_TRADING_AMOUNT_USD=5
# COPY_TRADING_SIMULATION=true

# --- API server (src/bin/api-server.ts) ---
PORT=4004
# DATA_API_BASE=https://data-api.polymarket.com
